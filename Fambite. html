function loadDPPanel(){
  const allOrders=Object.entries(users).flatMap(([u,d])=>(d.orders||[]).map(o=>({...o,_user:u})))
  const pending=allOrders.filter(o=>!['Delivered','Rejected'].includes(o.status||''))
  const body=document.getElementById('dpBody');if(!body)return
  body.innerHTML=pending.length?pending.map(o=>`
    <div class="dp-card">
      <div class="dp-card-top">
        <div>
          <div class="dp-id">Order #${o.id}</div>
          <div style="font-size:12px;color:var(--muted);font-weight:600">${o.restaurant} · ${o.date}</div>
        </div>
        <div class="dp-amt">₹${o.total}</div>
      </div>
      <div class="dp-addr">📍 Deliver to: <b>${o.village}, Ambala, Haryana</b><br>📦 Dispatched from: Bara Village<br>📱 ${o.phone||'—'}</div>
      <div style="font-size:13px;font-weight:700;margin-bottom:8px">🛍️ ${esc(o.items)}</div>
      <div class="dp-act-row">
        <button class="dp-accept" onclick="dpUpdateStatus('${o.id}','${o._user}','Out for Delivery')">✅ Accept</button>
        <button class="dp-reject" onclick="dpUpdateStatus('${o.id}','${o._user}','Rejected')">✗ Reject</button>
      </div>
      <button class="dp-deliver" onclick="dpUpdateStatus('${o.id}','${o._user}','Delivered')">🎉 Mark as Delivered</button>
    </div>`).join('')
    :'<div style="text-align:center;padding:60px 20px"><div style="font-size:40px;margin-bottom:12px">✅</div><div style="font-size:16px;font-weight:900">All Clear!</div><div style="font-size:13px;color:var(--muted);margin-top:5px">No pending deliveries</div></div>'
}
function dpUpdateStatus(orderId,userName,status){
  const ord=users[userName]?.orders?.find(o=>o.id===orderId)
  if(ord){ord.status=status;saveUsers();showToast('Updated: #'+orderId+' → '+status);loadDPPanel()}
}
function toggleDPStatus(){
  dpOnline=!dpOnline
  const dot=document.getElementById('dpDot');const txt=document.getElementById('dpStatusTxt')
  if(dot)dot.style.background=dpOnline?'#2ecc71':'#e74c3c'
  if(txt)txt.textContent=dpOnline?'Online — Ready to Deliver':'Offline'
  showToast(dpOnline?'🟢 You are now Online':'🔴 You are now Offline')
}

