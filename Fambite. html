// ── WALLET ──
function openWalletModal(){
  if(!currentUser)return
  const ud=getUD()
  const el=document.getElementById('walletAmtModal');if(el)el.textContent='₹'+(ud.wallet||0)
  const txEl=document.getElementById('walletTxList')
  const txs=[...(ud.walletTx||[])].reverse()
  if(txEl){
    txEl.innerHTML=txs.length?txs.map(t=>`
      <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid var(--bg)">
        <div>
          <div style="font-size:13px;font-weight:800">${esc(t.note)}</div>
          <div style="font-size:11px;color:var(--muted)">${esc(t.date||'')}</div>
        </div>
        <div style="font-size:15px;font-weight:900;color:${t.type==='credit'?'var(--green)':'var(--red)'}">${t.type==='credit'?'+':'-'}₹${t.amount}</div>
      </div>`).join('')
      :'<div style="text-align:center;padding:24px;font-size:13px;color:var(--muted)">No transactions yet</div>'
  }
  document.getElementById('walletModal').classList.add('active')
}
function copyRefCode(){
  const code=getUD()?.referralCode||''
  navigator.clipboard.writeText(code).then(()=>showToast('📋 Referral code copied: '+code)).catch(()=>showToast('Code: '+code))
}

// ── REVIEWS ──
function renderRestReviews(){
  const el=document.getElementById('restReviewsPreview');if(!el||!currentRest)return
  const revs=[]
  Object.entries(users).forEach(([u,d])=>{if(d.reviews&&d.reviews[currentRest.id])revs.push({user:u,name:d.name,...d.reviews[currentRest.id]})})
  if(!revs.length){el.innerHTML='<div style="font-size:13px;color:var(--muted);text-align:center;padding:10px">No reviews yet. Be the first! ⭐</div>';return}
  el.innerHTML=revs.slice(0,3).map(r=>`
    <div class="rev-card">
      <div class="rev-top">
        <div class="rev-author">${esc(r.name||r.user)}</div>
        <div>${'⭐'.repeat(r.rating)}</div>
      </div>
      <div class="rev-text">${esc(r.text||'')}</div>
      <div class="rev-date">${r.date||''}</div>
    </div>`).join('')
}
function openReviewModal(){
  if(!currentUser){showToast('Please login to leave a review');return}
  if(!currentRest)return
  revRestId=currentRest.id
  document.getElementById('reviewModalTitle').textContent='Rate '+currentRest.name
  revRating=0;setRevStar(0)
  document.getElementById('revText').value=''
  document.getElementById('reviewModal').classList.add('active')
}
function openReviewFromOrder(orderId){
  const ord=orders.find(o=>o.id===orderId)
  if(!ord)return
  const rest=RESTAURANTS.find(r=>r.name===ord.restaurant)
  if(rest){currentRest=rest;openReviewModal()}
}
function openReviewFromSuccess(){
  if(!cart.length&&orders.length){openReviewFromOrder(orders[orders.length-1].id)}
  else openReviewModal()
}
function setRevStar(n){
  revRating=n
  document.querySelectorAll('.rev-star').forEach((s,i)=>s.classList.toggle('on',i<n))
}
function submitReview(){
  if(!revRating){showToast('Please select a star rating');return}
  if(!currentUser)return
  const text=document.getElementById('revText').value.trim()
  const ud=getUD()
  const revs=ud.reviews||{}
  revs[revRestId]={rating:revRating,text,date:new Date().toLocaleDateString('en-IN')}
  setUD({reviews:revs})
  document.getElementById('reviewModal').classList.remove('active')
  showToast('⭐ Review submitted! Thank you!')
  renderRestReviews()
}

