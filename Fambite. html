function detectGPS(){
  if(!navigator.geolocation){showToast('GPS not supported, please select manually');return}
  showToast('📡 Detecting your location...')
  navigator.geolocation.getCurrentPosition(
    pos=>{
      // For demo: auto-assign Bara since we can't do real reverse geocoding without API
      showToast('📍 Location detected! Assigning nearest village...')
      setTimeout(()=>selectVillage('Bara'),800)
    },
    err=>{
      const msgs={1:'Permission denied. Please select manually.',2:'Location unavailable.',3:'Request timed out.'}
      showToast('❌ '+( msgs[err.code]||'GPS error'))
    },
    {timeout:8000,maximumAge:60000}
  )
}

function selectVillage(name){
  currentLocation=name
  document.getElementById('locName').textContent=name+', Ambala'
  document.getElementById('profileLoc').textContent='📍 '+name+', Ambala, Haryana'
  const sub=document.getElementById('profAddrSub');if(sub)sub.textContent=name+', Ambala, Haryana'
  if(currentUser){
    users[currentUser.username].location=name
    saveUsers()
  }
  document.querySelectorAll('.village-btn').forEach(b=>b.classList.toggle('selected',b.textContent.includes(name)))
  closeLocModal()
  document.getElementById('areaUnavailMsg').style.display='none'
  document.getElementById('mainContent').style.display='block'
  showToast('📍 Delivering to '+name)
}

function checkAreaAvailability(){
  if(!currentLocation){openLocModal();return false}
  if(!DELIVERY_VILLAGES.includes(currentLocation)){
    document.getElementById('areaUnavailMsg').style.display='block'
    document.getElementById('mainContent').style.display='none'
    return false
  }
  return true
}

