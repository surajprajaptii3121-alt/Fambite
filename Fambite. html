function showAuth(){showScreen('auth')}
function switchAuthTab(tab){
  authMode=tab
  document.querySelectorAll('.auth-tab').forEach((t,i)=>t.classList.toggle('active',(i===0&&tab==='login')||(i===1&&tab==='signup')))
  document.getElementById('loginForm').style.display=tab==='login'?'block':'none'
  document.getElementById('signupForm').style.display=tab==='signup'?'block':'none'
  document.getElementById('authBtn').textContent=tab==='login'?'Login →':'Create Account →'
  document.getElementById('authErr').textContent=''
}
function handleAuth(){
  const err=m=>document.getElementById('authErr').textContent=m
  if(authMode==='login'){
    const u=document.getElementById('loginUser').value.trim()
    const p=document.getElementById('loginPass').value
    if(!u||!p){err('Please fill in all fields');return}
    if(!users[u]||users[u].pass!==p){err('Invalid username or password');return}
    currentUser={...users[u],username:u}
    localStorage.setItem('fb_session',JSON.stringify({username:u}))
    loadApp()
  } else {
    const name=document.getElementById('signupName').value.trim()
    const u=document.getElementById('signupUser').value.trim()
    const ph=document.getElementById('signupPhone').value.trim()
    const p=document.getElementById('signupPass').value
    const ref=(document.getElementById('signupRef')?.value||'').trim().toUpperCase()
    if(!name||!u||!p){err('Please fill in all fields');return}
    if(ph&&(ph.length!==10||!/^\d+$/.test(ph))){err('Enter valid 10-digit phone number');return}
    if(p.length<4){err('Password must be at least 4 characters');return}
    if(users[u]){err('Username already taken!');return}
    // Referral validation
    let refBonus=0,refUser=null
    if(ref){
      refUser=Object.keys(users).find(k=>users[k].referralCode===ref)
      if(refUser){refBonus=50}
      else{err('Invalid referral code');return}
    }
    const newRefCode=u.substring(0,4).toUpperCase()+(Math.random()*9999|0).toString().padStart(4,'0')
    const initTx=refBonus?[{type:'credit',amount:50,note:'Referral bonus 🎁',date:new Date().toLocaleDateString('en-IN')}]:[]
    users[u]={name,pass:p,phone:ph,orders:[],saved:0,location:'',wallet:refBonus,walletTx:initTx,favorites:[],reviews:{},referralCode:newRefCode,referredBy:refUser||null,role:'user'}
    if(refUser){
      users[refUser].wallet=(users[refUser].wallet||0)+50
      users[refUser].walletTx=[...(users[refUser].walletTx||[]),{type:'credit',amount:50,note:'Referral reward — '+u+' joined!',date:new Date().toLocaleDateString('en-IN')}]
    }
    saveUsers()
    currentUser={...users[u],username:u}
    localStorage.setItem('fb_session',JSON.stringify({username:u}))
    if(refBonus) showToast('🎁 Referral valid! ₹50 added to your wallet!')
    loadApp()
  }
}
function logout(){
  currentUser=null;cart=[];orders=[];appliedCoupon=null;currentLocation=''
  localStorage.removeItem('fb_session')
  showScreen('splash')
  showToast('👋 Logged out successfully')
