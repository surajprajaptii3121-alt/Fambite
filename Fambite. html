function esc(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;')}
function saveUsers(){localStorage.setItem('fb_users',JSON.stringify(users))}
function getUD(){return users[currentUser.username]}
function setUD(data){users[currentUser.username]={...users[currentUser.username],...data};saveUsers()}
function goBackStatic(){showScreen(prevScr||'app')}
function showScreen(id){prevScr=document.querySelector('.screen.active')?.id||'app';document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));document.getElementById(id).classList.add('active');window.scrollTo(0,0)}
function showToast(msg,dur=2600){
  const t=document.getElementById('toast')
  t.textContent=msg;t.classList.add('show')
  clearTimeout(t._t);t._t=setTimeout(()=>t.classList.remove('show'),dur)
}
function copyCode(code){
  navigator.clipboard?.writeText(code).catch(()=>{})
  showToast(`📋 Coupon ${code} copied!`)
}

