function placeOrder(){
  const phone=document.getElementById('checkoutPhone').value.trim()
  if(!phone||phone.length!==10||!/^\d+$/.test(phone)){showToast('📱 Please enter a valid 10-digit phone number');return}
  if(!currentLocation){showToast('📍 Please select your delivery village');return}
  const{sub,tax,del,disc,walUsed,total}=calcBill()
  const rest=RESTAURANTS.find(r=>r.id===cart[0].restId)
  const orderId='FB'+Date.now().toString().slice(-6)
  const order={
    id:orderId,date:new Date().toLocaleString('en-IN'),
    restaurant:rest?rest.name:'',emoji:rest?rest.emoji:'🍽️',img:rest?rest.img:'',
    items:cart.map(c=>c.name+' ×'+c.qty).join(', '),
    itemDetails:[...cart],total,village:currentLocation,phone,
    instructions:document.getElementById('checkoutInstructions')?.value||'',
    status:'Confirmed',dispatchFrom:'Bara Village, Ambala, Haryana'
  }
  orders.push(order)
  // Deduct wallet if used
  if(walUsed>0){
    const ud=getUD()
    const newBal=Math.max(0,(ud.wallet||0)-walUsed)
    const tx=[...(ud.walletTx||[]),{type:'debit',amount:walUsed,note:'Order #'+orderId,date:new Date().toLocaleDateString('en-IN')}]
    setUD({wallet:newBal,walletTx:tx})
  }
  setUD({orders,saved:(getUD().saved||0)+disc})
  document.getElementById('orderIdBadge').textContent='Order #'+orderId+' · From Bara Village'
  buildTrackSteps(order)
  showScreen('orderSuccess')
  sendNotification('Order Confirmed! 🎉','Preparing in Bara Village!')
  setTimeout(()=>sendNotification('Preparing Your Food 👨‍🍳',`${rest?rest.name:'Restaurant'} is cooking your order!`),15000)
  setTimeout(()=>sendNotification('Out for Delivery! 🛵','On its way from Bara to '+currentLocation+'!'),30000)
  setTimeout(()=>sendNotification('Delivered! 🎉','Enjoy your meal! Rate us ⭐'),45000)
  cart=[];appliedCoupon=null;updateCartBadge()
  updateProfileStats()
  document.getElementById('bnOrderDot').classList.add('show')
  // Loyalty check — every 5 orders earn ₹50
  const cnt=orders.length
  if(cnt%5===0){
    const ud=getUD()
    const newBal=(ud.wallet||0)+50
    const tx=[...(ud.walletTx||[]),{type:'credit',amount:50,note:'🏆 Loyalty reward — '+cnt+' orders!',date:new Date().toLocaleDateString('en-IN')}]
    setUD({wallet:newBal,walletTx:tx})
    setTimeout(()=>showToast('🏆 Loyalty reward! ₹50 added to wallet!'),2000)
  }
}

function buildTrackSteps(order){
  const steps=[
