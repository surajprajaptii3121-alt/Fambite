  if(!cart.length){showToast('Cart is empty');backFromCart();return}
  renderCartItems();renderBill();updateCartBadge()
}

function calcBill(){
  const sub=cart.reduce((s,c)=>s+c.price*c.qty,0)
  const tax=Math.round(sub*.05)
  let del=sub>=299?0:30
  let disc=0
  if(appliedCoupon){
    const c=COUPONS[appliedCoupon]
    if(c&&c.type==='flat') disc=Math.min(c.discount,sub)
    if(c&&c.type==='percent') disc=Math.round(sub*c.discount/100)
    if(c&&c.type==='freedel') del=0
  }
  const walBal=currentUser?getUD().wallet||0:0
  const useWal=document.getElementById('useWalletChk')?.checked
  const walUsed=useWal?Math.min(walBal,sub+tax+del-disc):0
  const total=Math.max(0,sub+tax+del-disc-walUsed)
  return{sub,tax,del,disc,walUsed,total}
}
function renderBill(){
  const{sub,tax,del,disc,walUsed,total}=calcBill()
  document.getElementById('billItems').textContent='₹'+sub
  document.getElementById('billDel').textContent=del===0?'🎉 FREE':'₹'+del
  document.getElementById('billTax').textContent='₹'+tax
  document.getElementById('billTotal').textContent='₹'+total
  const dr=document.getElementById('discountRow')
  if(disc>0){dr.style.display='flex';document.getElementById('billDiscount').textContent='-₹'+disc}
  else dr.style.display='none'
  const wr=document.getElementById('walletBillRow')
  if(wr){if(walUsed>0){wr.style.display='flex';document.getElementById('billWalletAmt').textContent='-₹'+walUsed}else wr.style.display='none'}
  const sb=document.getElementById('savingsBanner')
  const totalSave=disc+(del===0&&sub<299?30:0)+walUsed
  if(totalSave>0){sb.style.display='flex';document.getElementById('savingsAmt').textContent='₹'+totalSave}
  else sb.style.display='none'
  // Update wallet balance display in cart
  const wbc=document.getElementById('walletBalCart');if(wbc&&currentUser)wbc.textContent='₹'+(getUD().wallet||0)
}

function setCoupon(code){document.getElementById('couponInput').value=code;applyCoupon()}
function applyCoupon(){
  const code=document.getElementById('couponInput').value.trim().toUpperCase()
  const msgEl=document.getElementById('couponMsg')
  if(COUPONS[code]){
    appliedCoupon=code
    msgEl.textContent=COUPONS[code].msg
    msgEl.style.color='var(--green)'
