function updateProfileStats(){
  if(!currentUser)return
  const ud=getUD()
  document.getElementById('pOrderCount').textContent=orders.length
  document.getElementById('pSaved').textContent='₹'+(ud.saved||0)
  document.getElementById('orderCountBadge').textContent=orders.length
  // Wallet
  const wal=ud.wallet||0
  const wEl=document.getElementById('pWallet');if(wEl)wEl.textContent='₹'+wal
  const waEl=document.getElementById('walletAmt');if(waEl)waEl.textContent='₹'+wal
  // Loyalty
  const prog=orders.length%5
  const pct=prog/5*100
  const lf=document.getElementById('loyaltyFill');if(lf)lf.style.width=pct+'%'
  const lc=document.getElementById('loyaltyCount');if(lc)lc.textContent=prog+'/5 orders'
  const ls=document.getElementById('loyaltySub')
  if(ls)ls.textContent=prog===0&&orders.length>0?'🏆 Reward claimed! Keep ordering!':(5-prog)+' more order'+(5-prog>1?'s':'')+' to earn ₹50 wallet credit!'
}

