    {icon:'👨‍🍳',label:'Preparing Food',sub:'Prepared fresh in Bara Village, Ambala',time:'~15-20 mins',active:true},
    {icon:'📦',label:'Dispatched from Bara',sub:'Dispatched from Bara Village, Ambala, Haryana',time:'~20-25 mins',done:false},
    {icon:'🛵',label:'Out for Delivery',sub:'On the way to '+order.village,time:'~25-35 mins',done:false},
    {icon:'🏠',label:'Delivered to '+order.village,sub:'Enjoy your meal!',time:'~40-50 mins',done:false},
  ]
  document.getElementById('trackSteps').innerHTML=steps.map(s=>`
    <div class="track-step${s.done?' done':''}">
      <div class="step-icon ${s.done?'done':s.active?'active-step':''}">${s.icon}</div>
