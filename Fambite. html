    list.innerHTML=`<div class="empty-state" style="padding:60px 24px"><div class="empty-icon">📦</div><div class="empty-title">No orders yet!</div><div class="empty-sub">Your order history will appear here</div><button style="margin-top:16px;padding:12px 28px;background:var(--red);color:#fff;border-radius:12px;font-size:14px;font-weight:800" onclick="switchTab('home')">Order Now →</button></div>`
    return
  }
  list.innerHTML=[...orders].reverse().map(o=>`
    <div class="order-card">
      <div class="order-card-top">
        <div class="order-rest-info">
          <div class="order-rest-img"><img src="${o.img||''}" alt="${esc(o.restaurant)}" loading="lazy" onerror="this.style.display='none'"></div>
          <div>
            <div class="order-rest-name">${esc(o.restaurant)}</div>
            <div class="order-rest-date">${o.date} · ${o.village}</div>
          </div>
        </div>
        <div class="order-status status-delivered">${o.status}</div>
      </div>
      <div class="order-items">${esc(o.items)}</div>
      <div class="order-track-mini">
        ${['Confirmed','Preparing','Delivered','✓'].map((s,i)=>`<div class="mini-step"><div class="mini-dot done">${i===3?'✓':i+1}</div><div class="mini-label">${s}</div></div>`).join('')}
      </div>
      <div class="order-footer" style="margin-top:12px">
        <div class="order-total">₹${o.total}</div>
        <button class="reorder-btn" onclick="reorder(${JSON.stringify(o.id).replace(/'/g,'')})">🔄 Reorder</button>
        <button onclick="openReviewFromOrder('${o.id}')" style="padding:7px 12px;background:var(--bg);border-radius:10px;font-size:12px;font-weight:800;border:none;cursor:pointer">⭐ Review</button>
      </div>
      <div style="font-size:11px;color:var(--muted);margin-top:6px">Order ID: ${o.id} · Dispatched from Bara Village</div>
    </div>
  `).join('')
}

function reorder(orderId){
  const order=orders.find(o=>o.id===orderId)
  if(!order||!order.itemDetails){showToast('Opening restaurant...');return}
  const rest=RESTAURANTS.find(r=>r.name===order.restaurant)
  if(rest){openRestaurant(rest.id);showToast('🔄 Menu opened — add items to cart!')}
}

/* ══════════════════════════════════════
   TABS
══════════════════════════════════════ */
function switchTab(tab){
  document.querySelectorAll('[id$="Tab"]').forEach(t=>t.style.display='none')
  document.querySelectorAll('.bn-item').forEach(b=>b.classList.remove('active'))
  const tabMap={home:'homeTab',search:'searchTab',orders:'ordersTab',profile:'profileTab'}
  const el=document.getElementById(tabMap[tab])
  if(el) el.style.display='block'
  const bn=document.getElementById('bn-'+tab)
  if(bn) bn.classList.add('active')
  if(tab==='orders'){renderOrders();document.getElementById('bnOrderDot').classList.remove('show')}
  if(tab==='profile') updateProfileStats()
  if(tab==='search') setTimeout(()=>document.getElementById('searchTabInput').focus(),100)
  if(tab==='home') checkAreaAvailability()
  showScreen('app')
}

