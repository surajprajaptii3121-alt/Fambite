function getRestRating(id,def){
  const all=[]
  Object.values(users).forEach(u=>{if(u.reviews&&u.reviews[id])all.push(u.reviews[id].rating)})
  return all.length?(all.reduce((a,b)=>a+b,0)/all.length).toFixed(1):def
}
function renderRestaurants(list){
  const grid=document.getElementById('restGrid')
  const noRes=document.getElementById('noResults')
  if(!list.length){grid.innerHTML='';noRes.style.display='block';return}
  noRes.style.display='none'
  const favs=currentUser?getUD().favorites||[]:[]
  grid.innerHTML=list.map(r=>`
    <div class="rest-card" onclick="openRestaurant(${r.id})">
      <div class="rest-img">
        <img src="${r.img}" alt="${esc(r.name)}" loading="lazy" onerror="this.style.display='none';this.parentElement.style.background='${r.bg||'#e23744'}'">
        <div class="rest-img-overlay"></div>
        <div class="rest-img-badge">⏱ ${r.time} mins</div>
        ${r.offer?`<div class="rest-offer">🏷️ OFFER</div>`:''}
        <button class="rest-fav" onclick="event.stopPropagation();favToggle(this,${r.id})">${favs.includes(r.id)?'❤️':'🤍'}</button>
      </div>
      <div class="rest-body">
        <div class="rest-name">${esc(r.name)}</div>
        <div class="rest-meta">
          <div class="rest-rating">⭐ ${r.rating}</div>
          <span>·</span><span>${r.time} mins</span>
          <span>·</span><span>${r.price}</span>
        </div>
        <div class="rest-tags">${r.tags.map(t=>`<span class="tag">${t}</span>`).join('')}</div>
      </div>
    </div>
  `).join('')
}

function favToggle(btn,id){
  if(!currentUser)return
  const favs=getUD().favorites||[]
  const idx=favs.indexOf(id)
  if(idx===-1){favs.push(id);btn.textContent='❤️';showToast('❤️ Added to favourites!')}
  else{favs.splice(idx,1);btn.textContent='🤍';showToast('Removed from favourites')}
  setUD({favorites:favs})
}
function toggleDetailFav(){
  if(!currentRest||!currentUser)return
  const favs=getUD().favorites||[]
