    activeFilters=new Set(['all'])
    document.querySelectorAll('.filter-pill').forEach(p=>p.classList.remove('active'))
    el.classList.add('active')
  } else {
    activeFilters.delete('all')
    document.querySelector('.filter-pill').classList.remove('active')
    el.classList.toggle('active')
    if(el.classList.contains('active')) activeFilters.add(type)
    else activeFilters.delete(type)
    if(activeFilters.size===0){activeFilters.add('all');document.querySelector('.filter-pill').classList.add('active')}
  }
  applyFiltersAndSearch()
}

