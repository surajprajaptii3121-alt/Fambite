function adminUpdateOrder(orderId,status){
  Object.keys(users).forEach(u=>{
    const ord=users[u].orders?.find(o=>o.id===orderId)
    if(ord){ord.status=status;saveUsers()}
  })
  showToast('✅ Order #'+orderId+' → '+status)
}

