function applyFiltersAndSearch(cat=''){
  const q=document.getElementById('searchInput').value.toLowerCase()
  const activeCat=cat||(document.querySelector('.cat-chip.active')||{}).dataset?.cat||'all'
  let list=RESTAURANTS
  if(activeCat&&activeCat!=='all') list=list.filter(r=>r.category===activeCat)
  if(q) list=list.filter(r=>r.name.toLowerCase().includes(q)||r.tags.some(t=>t.toLowerCase().includes(q))||r.menu.some(mc=>mc.items.some(i=>i.name.toLowerCase().includes(q))))
  if(activeFilters.has('veg')) list=list.filter(r=>r.menu.some(mc=>mc.items.some(i=>i.veg)))
  if(activeFilters.has('rating')) list=list.filter(r=>r.rating>=4)
  if(activeFilters.has('fast')) list=list.filter(r=>parseInt(r.time)<=30)
  if(activeFilters.has('offers')) list=list.filter(r=>r.offer)
  renderRestaurants(list)
}

