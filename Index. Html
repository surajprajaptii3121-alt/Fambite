let appliedCoupon = null
let orders = []

// ── UTILS ─────────────────────────────────────────────────
function showScreen(id){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'))
  document.getElementById(id).classList.add('active')
}

function showToast(msg){
  const t = document.getElementById('toast')
  t.textContent = msg
  t.classList.add('show')
  clearTimeout(t._timer)
  t._timer = setTimeout(()=>t.classList.remove('show'),2500)
}

function escapeHTML(s){ return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;') }

// ── AUTH ──────────────────────────────────────────────────
function showAuth(){ showScreen('auth') }

function switchTab(tab){
  activeTab = tab
  document.querySelectorAll('.auth-tab').forEach((t,i)=>t.classList.toggle('active',(i===0&&tab==='login')||(i===1&&tab==='signup')))
  document.getElementById('loginForm').style.display = tab==='login'?'block':'none'
  document.getElementById('signupForm').style.display = tab==='signup'?'block':'none'
  document.getElementById('authBtn').textContent = tab==='login'?'Login':'Create Account'
  document.getElementById('authErr').textContent = ''
}

function handleAuth(){
  const err = id => document.getElementById('authErr').textContent = id
  if(activeTab==='login'){
    const u = document.getElementById('loginUser').value.trim()
    const p = document.getElementById('loginPass').value
    if(!u||!p){ err('Please fill in all fields'); return }
    if(!users[u]||users[u].pass!==p){ err('Invalid username or password'); return }
    currentUser = {...users[u], username:u}
    loadApp()
  } else {
    const name = document.getElementById('signupName').value.trim()
    const u = document.getElementById('signupUser').value.trim()
    const p = document.getElementById('signupPass').value
    if(!name||!u||!p){ err('Please fill in all fields'); return }
    if(p.length<4){ err('Password must be at least 4 characters'); return }
    if(users[u]){ err('Username already taken!'); return }
    users[u] = {name, pass:p, orders:[], saved:0}
    localStorage.setItem('fb_users', JSON.stringify(users))
    currentUser = {name, username:u, orders:[], saved:0}
    loadApp()
  }
}

function loadApp(){
  const h = new Date().getHours()
  const greeting = h<12?'Good morning':h<17?'Good afternoon':'Good evening'
  document.getElementById('heroGreet').textContent = greeting + ', ' + currentUser.name.split(' ')[0] + ' 👋'
  document.getElementById('profileName').textContent = currentUser.name
  document.getElementById('profileEmail').textContent = currentUser.username + '@fambite.com'
  orders = users[currentUser.username].orders || []
  updateProfileStats()
  renderRestaurants(RESTAURANTS)
  showScreen('app')
  updateCartBadge()
}

function logout(){
  currentUser=null; cart=[]; orders=[]; appliedCoupon=null
  showScreen('splash')
}

// ── RESTAURANTS ───────────────────────────────────────────
function renderRestaurants(list){
  const grid = document.getElementById('restGrid')
  const noRes = document.getElementById('noResults')
  if(!list.length){ grid.innerHTML=''; noRes.style.display='block'; return }
  noRes.style.display='none'
  grid.innerHTML = list.map(r=>`
    <div class="rest-card" onclick="openRestaurant(${r.id})">
      <div class="rest-img" style="background:${r.bg}">
        <span>${r.emoji}</span>
        <div class="rest-img-badge">⏱ ${r.time} mins</div>
        ${r.offer?`<div class="rest-offer">🏷️ OFFER</div>`:''}
        <button class="rest-fav" onclick="event.stopPropagation();favToggle(this)">🤍</button>
      </div>
      <div class="rest-body">
        <div class="rest-name">${escapeHTML(r.name)}</div>
        <div class="rest-meta">
          <div class="rest-rating">⭐ ${r.rating}</div>
          <span>${r.time} mins</span>
          <span>${r.price}</span>
        </div>
        <div class="rest-tags">${r.tags.map(t=>`<span class="tag">${t}</span>`).join('')}</div>
      </div>
    </div>
  `).join('')
}

function favToggle(btn){ btn.textContent = btn.textContent==='🤍'?'❤️':'🤍'; showToast(btn.textContent==='❤️'?'Added to favourites!':'Removed from favourites') }

function filterCat(cat,el){
  document.querySelectorAll('.cat-chip').forEach(c=>c.classList.remove('active'))
  el.classList.add('active')
  renderRestaurants(cat==='all'?RESTAURANTS:RESTAURANTS.filter(r=>r.category===cat))
}

function filterRestaurants(){
  const q = document.getElementById('searchInput').value.toLowerCase()
  renderRestaurants(RESTAURANTS.filter(r=>r.name.toLowerCase().includes(q)||r.tags.some(t=>t.toLowerCase().includes(q))))
}

// ── RESTAURANT DETAIL ─────────────────────────────────────
function openRestaurant(id){
  currentRest = RESTAURANTS.find(r=>r.id===id)
  if(!currentRest) return
  document.getElementById('detailHero').style.background = currentRest.bg
  document.getElementById('detailHero').querySelector('button').insertAdjacentHTML('afterend',`<span style="font-size:80px">${currentRest.emoji}</span>`)
  // clean up duplicates
  const spans = document.getElementById('detailHero').querySelectorAll('span')
  spans.forEach((s,i)=>{ if(i>0) s.remove() })

  document.getElementById('detailName').textContent = currentRest.name
  document.getElementById('detailMeta').innerHTML = `
    <div class="detail-stat"><span class="val green-chip">⭐ ${currentRest.rating}</span></div>
    <div class="detail-stat"><span>⏱</span><span class="val">${currentRest.time} mins</span></div>
    <div class="detail-stat"><span>💰</span><span class="val">${currentRest.price}</span></div>
    <div class="detail-stat"><span>📍</span><span class="val">Yamuna Nagar</span></div>
  `
  document.getElementById('detailOffer').textContent = currentRest.offer
  renderMenu(currentRest.menu)
  showScreen('restDetail')
  updateCartBar()
}

function renderMenu(menu, filter=''){
  const ml = document.getElementById('menuList')
  ml.innerHTML = menu.map(cat=>{
    const items = cat.items.filter(i=>!filter||i.name.toLowerCase().includes(filter)||i.desc.toLowerCase().includes(filter))
    if(!items.length) return ''
    return `<div class="menu-category">
      <div class="menu-cat-title">${escapeHTML(cat.cat)} (${items.length})</div>
      ${items.map(item=>{
        const inCart = cart.find(c=>c.id===item.id)
        return `<div class="menu-item" id="menurow${item.id}">
          <div class="menu-item-body">
            <div class="veg-dot ${item.veg?'veg':'non-veg'}"></div>
            <div class="item-name">${escapeHTML(item.name)}</div>
            <div class="item-desc">${escapeHTML(item.desc)}</div>
            <div class="item-price">₹${item.price}</div>
          </div>
          <div style="display:flex;flex-direction:column;align-items:center;gap:8px">
            <div class="menu-item-img">${item.emoji}</div>
            ${inCart
              ? `<div class="qty-ctrl"><button class="qty-btn" onclick="changeQty(${item.id},-1)">−</button><span class="qty-num">${inCart.qty}</span><button class="qty-btn" onclick="changeQty(${item.id},1)">+</button></div>`
              : `<button class="item-add-btn" onclick="addToCart(${item.id})">ADD</button>`
            }
          </div>
        </div>`
      }).join('')}
    </div>`
  }).join('')
}

function filterMenu(){
  const q = document.getElementById('menuSearchInput').value.toLowerCase()
  renderMenu(currentRest.menu, q)
}

function addToCart(itemId){
  const item = currentRest.menu.flatMap(c=>c.items).find(i=>i.id===itemId)
  if(!item) return
  const existing = cart.find(c=>c.id===itemId)
  if(existing){ existing.qty++ } else { cart.push({...item, restId:currentRest.id, restName:currentRest.name, restEmoji:currentRest.emoji, qty:1}) }
  renderMenu(currentRest.menu, document.getElementById('menuSearchInput').value.toLowerCase())
  updateCartBar()
  updateCartBadge()
  showToast('Added to cart! 🛒')
}

function changeQty(itemId, delta){
  const idx = cart.findIndex(c=>c.id===itemId)
  if(idx===-1) return
  cart[idx].qty += delta
  if(cart[idx].qty<=0) cart.splice(idx,1)
  renderMenu(currentRest.menu, document.getElementById('menuSearchInput').value.toLowerCase())
  updateCartBar()
  updateCartBadge()
}

function updateCartBar(){
  const bar = document.getElementById('cartBar')
  const total = cart.reduce((s,c)=>s+c.price*c.qty,0)
  const count = cart.reduce((s,c)=>s+c.qty,0)
  if(count>0&&currentRest){
    bar.classList.add('show')
    document.getElementById('cartBarCount').textContent = count+' item'+(count>1?'s':'')+' · ₹'+total
    document.getElementById('cartBarRest').textContent = currentRest.name
  } else { bar.classList.remove('show') }
}

function updateCartBadge(){
  const count = cart.reduce((s,c)=>s+c.qty,0)
  const b = document.getElementById('cartBadge')
  b.style.display = count>0?'flex':'none'
  b.textContent = count
}

function backToHome(){ showScreen('app'); document.getElementById('cartBar').classList.remove('show') }

// ── CART ──────────────────────────────────────────────────
function showCart(){
  if(!cart.length){ showToast('Your cart is empty!'); return }
  const rest = RESTAURANTS.find(r=>r.id===cart[0].restId)
  document.getElementById('cartRestEmoji').textContent = rest?rest.emoji:'🍽️'
  document.getElementById('cartRestName').textContent = rest?rest.name:''
  document.getElementById('cartRestSub').textContent = (rest?rest.time+' mins · ':'')+cart.reduce((s,c)=>s+c.qty,0)+' items'
  renderCartItems()
  renderBill()
  showScreen('cartScreen')
}

function renderCartItems(){
  const box = document.getElementById('cartItemsBox')
  box.innerHTML = cart.map(item=>`
    <div class="cart-item-row">
      <div class="ci-emoji">${item.emoji}</div>
      <div class="ci-info">
        <div class="ci-name">${escapeHTML(item.name)}</div>
        <div class="ci-price">₹${item.price} each</div>
      </div>
      <div class="ci-ctrl">
        <button class="ci-btn" onclick="cartChangeQty(${item.id},-1)">−</button>
        <span class="ci-qty">${item.qty}</span>
        <button class="ci-btn" onclick="cartChangeQty(${item.id},1)">+</button>
      </div>
    </div>
  `).join('')
}

function cartChangeQty(itemId, delta){
  const idx = cart.findIndex(c=>c.id===itemId)
  if(idx===-1) return
  cart[idx].qty+=delta
  if(cart[idx].qty<=0) cart.splice(idx,1)
  if(!cart.length){ showToast('Cart is empty'); backFromCart(); return }
  renderCartItems()
  renderBill()
  updateCartBadge()
}

function renderBill(){
  const sub = cart.reduce((s,c)=>s+c.price*c.qty,0)
  const tax = Math.round(sub*0.05)
  let del = sub>=299?0:30
  let disc = 0
  if(appliedCoupon){
    const c = COUPONS[appliedCoupon]
    if(c.type==='flat') disc=Math.min(c.discount,sub)
    if(c.type==='freedel') del=0
  }
  const total = sub+tax+del-disc
  document.getElementById('billItems').textContent='₹'+sub
  document.getElementById('billDel').textContent=del===0?'FREE':'₹'+del
  document.getElementById('billTax').textContent='₹'+tax
  document.getElementById('billTotal').textContent='₹'+total
  const dr = document.getElementById('discountRow')
  if(disc>0||appliedCoupon&&COUPONS[appliedCoupon].type==='freedel'){
    dr.style.display='flex'
    document.getElementById('billDiscount').textContent=disc>0?'-₹'+disc:'-₹'+30
  } else dr.style.display='none'
}

function setCoupon(code){ document.getElementById('couponInput').value=code }

function applyCoupon(){
  const code = document.getElementById('couponInput').value.trim().toUpperCase()
  const msg = document.getElementById('couponMsg')
  if(COUPONS[code]){ appliedCoupon=code; msg.textContent=COUPONS[code].msg; msg.style.color='var(--green)'; renderBill() }
  else { msg.textContent='Invalid coupon code ❌'; msg.style.color='var(--red)' }
}

function backFromCart(){
  if(currentRest) showScreen('restDetail')
  else showScreen('app')
}

// ── ORDER ─────────────────────────────────────────────────
function placeOrder(){
  if(!cart.length) return
  const sub = cart.reduce((s,c)=>s+c.price*c.qty,0)
  const tax = Math.round(sub*0.05)
  const del = sub>=299?0:30
  let disc=0
  if(appliedCoupon&&COUPONS[appliedCoupon].type==='flat') disc=Math.min(COUPONS[appliedCoupon].discount,sub)
  const total = sub+tax+del-disc
  const rest = RESTAURANTS.find(r=>r.id===cart[0].restId)
  const order = {
    id:'FB'+Date.now(), date:new Date().toLocaleString(),
    restaurant:rest?rest.name:'', emoji:rest?rest.emoji:'🍽️',
    items:cart.map(c=>c.name+' x'+c.qty).join(', '),
    total, status:'Delivered'
  }
  orders.push(order)
  users[currentUser.username].orders = orders
  users[currentUser.username].saved += disc
  localStorage.setItem('fb_users',JSON.stringify(users))
  cart=[]; appliedCoupon=null
  updateCartBadge()
  updateProfileStats()
  showScreen('orderSuccess')
}

function backHome(){ showScreen('app'); switchTab2('home') }

// ── ORDERS TAB ────────────────────────────────────────────
function renderOrders(){
  const list = document.getElementById('ordersList')
  if(!orders.length){ list.innerHTML='<div style="text-align:center;padding:40px;color:var(--muted)"><div style="font-size:48px">📦</div><div style="font-size:16px;font-weight:700;margin-top:10px">No orders yet!</div><div style="font-size:13px;margin-top:6px">Your order history will appear here</div></div>'; return }
  list.innerHTML=[...orders].reverse().map(o=>`
    <div class="order-card">
      <div class="order-card-top">
        <div style="display:flex;align-items:center;gap:10px"><span style="font-size:28px">${o.emoji}</span><div class="order-rest-name">${escapeHTML(o.restaurant)}</div></div>
        <div class="order-status status-delivered">${o.status}</div>
      </div>
      <div class="order-items">${escapeHTML(o.items)}</div>
      <div class="order-footer">
        <div class="order-total">₹${o.total}</div>
        <button class="reorder-btn" onclick="showToast('Reorder coming soon!')">Reorder</button>
      </div>
      <div style="font-size:11px;color:var(--muted);margin-top:6px">${o.date} · Order #${o.id}</div>
    </div>
  `).join('')
}

// ── TABS ──────────────────────────────────────────────────
function switchTab2(tab){
  ['home','search','orders','profile'].forEach(t=>{
    document.getElementById(t+'Tab').style.display = t===tab||(t==='home'&&tab==='search')?'block':'none'
    const bn = document.getElementById('bn-'+t)
    if(bn) bn.classList.toggle('active',t===tab)
  })
  if(tab==='search'){ document.getElementById('homeTab').style.display='block'; setTimeout(()=>document.getElementById('searchInput').focus(),100) }
  if(tab==='orders') renderOrders()
  if(tab==='profile') updateProfileStats()
}

function updateProfileStats(){
  document.getElementById('pOrderCount').textContent = orders.length
  document.getElementById('pSaved').textContent = '₹'+(users[currentUser?.username]?.saved||0)
}

// ── INIT ──────────────────────────────────────────────────
// Add demo accounts
if(!users['demo']){ users['demo']={name:'Demo User',pass:'demo',orders:[],saved:0}; localStorage.setItem('fb_users',JSON.stringify(users)) }
if(!users['admin']){ users['admin']={name:'Admin',pass:'admin123',orders:[],saved:0}; localStorage.setItem('fb_users',JSON.stringify(users)) }

// Set greeting helper
function h_helper(h){ return h<12?'Good morning':h<17?'Good afternoon':'Good evening' }
</script>
